# 复制本文件为 .env，然后填入你的真实 API Key。
# 不填 Key 时，项目会自动使用本地 RAG 兜底，仍可正常演示。

# 可选：deepseek 或 qwen
LINGSHAN_LLM_PROVIDER=deepseek

# DeepSeek 示例：
DEEPSEEK_API_KEY=sk-your-deepseek-key
LINGSHAN_LLM_MODEL=deepseek-chat
LINGSHAN_LLM_BASE_URL=https://api.deepseek.com

# Qwen / 通义千问示例：
# LINGSHAN_LLM_PROVIDER=qwen
# DASHSCOPE_API_KEY=sk-your-dashscope-key
# LINGSHAN_LLM_MODEL=qwen-plus
# LINGSHAN_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Aliyun NLS TTS with phoneme timestamps for digital-human lip sync.
# Token is temporary; refresh it in the Aliyun console after it expires.
ALIYUN_NLS_APPKEY=your-aliyun-nls-appkey
ALIYUN_NLS_TOKEN=your-aliyun-nls-token
ALIYUN_NLS_VOICE=siyue
ALIYUN_NLS_SAMPLE_RATE=24000

# Azure Speech TTS with 60 FPS FacialExpression blendshapes for TalkingHead tests.
AZURE_SPEECH_REGION=southeastasia
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_VOICE=zh-CN-XiaoxiaoNeural
AZURE_SPEECH_LANG=zh-CN
